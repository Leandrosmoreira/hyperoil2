# =============================================================================
# HyperOil v2 — Donchian strategy environment template
# =============================================================================
# Copy this file to `.env` on the VPS and fill in real values:
#     cp .env.donchian.template .env
#     chmod 600 .env
#     nano .env
#
# NEVER commit the populated .env. The repository .gitignore already excludes
# it, but double-check before any `git add` you didn't override it.
# =============================================================================

# -----------------------------------------------------------------------------
# Hyperliquid account credentials
# -----------------------------------------------------------------------------
# The wallet that signs orders. Use a DEDICATED API/sub-account for the bot —
# never the wallet that holds your treasury.
HYPERLIQUID_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: if you trade on behalf of a master account via API wallet, set this
# to the master account public address. Leave empty if PRIVATE_KEY is already
# the trading account.
HYPERLIQUID_ACCOUNT_ADDRESS=

# Mainnet vs testnet. For paper-mode runs you can leave this on mainnet — paper
# mode never sends orders, it just listens to real market data.
HYPERLIQUID_NETWORK=mainnet

# -----------------------------------------------------------------------------
# Optional overrides (can also live in donchian_config.yaml)
# -----------------------------------------------------------------------------
# Force execution mode regardless of YAML — paper / live
# HYPEROIL_EXECUTION_MODE=paper

# Override structured-log level — DEBUG / INFO / WARNING / ERROR
# HYPEROIL_LOG_LEVEL=INFO
