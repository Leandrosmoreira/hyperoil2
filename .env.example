# HyperOil v2 — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Hyperliquid credentials
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# Execution mode override (paper | live)
# HYPEROIL_EXECUTION_MODE=paper

# Log level override
# HYPEROIL_LOG_LEVEL=DEBUG

# Health endpoint port override
# HYPEROIL_HEALTH_PORT=8080
